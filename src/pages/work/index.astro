---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import japanTimesLogo from '../../assets/images/TheJapanTimes - header_logo.svg';
import itoEnLogo from '../../assets/images/ItoEn - header_logo.svg';
import timeOutLogo from '../../assets/images/Time_Out_Tokyo_JP_idb097FX2z_1.svg';
import hotelTavinosLogo from '../../assets/images/Hotel Tavinos - logo.svg';
import microLubLogo from '../../assets/images/Microlub-logo.svg';

const pubLogos: Record<string, { src: string }> = {
    'The Japan Times': japanTimesLogo,
    'Time Out': timeOutLogo,
    'Time Out Osaka': timeOutLogo,
    'Ito-en': itoEnLogo,
    'Hotel Tavinos Kyoto': hotelTavinosLogo,
    'Micro Lub': microLubLogo,
};

const entries = (await getCollection('work'))
    .filter((e) => !e.data.draft && e.data.type && e.data.date && e.data.title)
    .sort((a, b) => b.data.date!.valueOf() - a.data.date!.valueOf());

function formatDate(date: Date) {
    return date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
}
---

<BaseLayout
    title="Work"
    description="Writing by Edward Hewes — editorial pieces and commercial content."
>
    <div class="page-content">
        <h1 class="page-title">Work</h1>

        <ul class="work-filter" role="list" aria-label="Filter by type">
            <li>
                <button class="is-active" data-filter="all" aria-pressed="true">All</button>
            </li>
            <li aria-hidden="true" class="work-filter__sep">—</li>
            <li>
                <button data-filter="editorial" aria-pressed="false">Editorial</button>
            </li>
            <li aria-hidden="true" class="work-filter__sep">—</li>
            <li>
                <button data-filter="commercial" aria-pressed="false">Commercial</button>
            </li>
        </ul>

        <ul class="work-list" role="list">
            {
                entries.map((entry) => {
                    const logo = pubLogos[entry.data.publication];
                    return (
                        <li class="work-entry" data-type={entry.data.type}>
                            <p class="work-entry__meta">
                                {logo && (
                                    <img
                                        src={logo.src}
                                        alt=""
                                        aria-hidden="true"
                                        class="pub-logo"
                                    />
                                )}
                                <span>{entry.data.publication}</span>
                                <span aria-hidden="true">—</span>
                                <time datetime={entry.data.date.toISOString()}>
                                    {formatDate(entry.data.date)}
                                </time>
                            </p>
                            <h2 class="work-entry__title">
                                {entry.data.url ? (
                                    <a
                                        href={entry.data.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                    >
                                        {entry.data.title}
                                    </a>
                                ) : (
                                    entry.data.title
                                )}
                            </h2>
                            <p class="work-entry__excerpt">{entry.data.excerpt}</p>
                            {entry.data.url && (
                                <a
                                    href={entry.data.url}
                                    class="work-entry__link"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    aria-label={`Read: ${entry.data.title}`}
                                >
                                    Read piece →
                                </a>
                            )}
                        </li>
                    );
                })
            }
        </ul>
    </div>
</BaseLayout>

<script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const entries = document.querySelectorAll<HTMLElement>('[data-type]');

    buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
            const filter = btn.dataset.filter!;

            buttons.forEach((b) => {
                b.classList.remove('is-active');
                b.setAttribute('aria-pressed', 'false');
            });
            btn.classList.add('is-active');
            btn.setAttribute('aria-pressed', 'true');

            entries.forEach((entry) => {
                if (filter === 'all' || entry.dataset.type === filter) {
                    entry.hidden = false;
                } else {
                    entry.hidden = true;
                }
            });
        });
    });
</script>
