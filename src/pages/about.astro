---
import { Image } from 'astro:assets';
import profilePhoto from '../assets/images/Edward Hewes - Profile Image.JPG';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="About"
    description="Edward Hewes is a freelance writer working across editorial and commercial projects."
>
    <div class="page-content">
        <h1 class="page-title">About</h1>
        <div class="about-layout">
            <figure class="about-photo">
                <Image
                    src={profilePhoto}
                    alt="Edward Hewes"
                    widths={[400, 700]}
                    sizes="(max-width: 600px) 100vw, 50vw"
                />
            </figure>
            <div class="about-body">
                <p>
                    Edward Hewes is a freelance writer working across editorial
                    and commercial projects.
                </p>
                <p>
                    His editorial work appears regularly in Time Out Osaka and
                    The Japan Times, where he covers culture, food, events, and
                    neighbourhoods across Japan.
                </p>
                <p>
                    On the commercial side, he writes SEO and marketing content
                    for international brands — including cornerstone content for Ito-en, Japan's biggest tea manafacturer; SEO content for Hotel Tavinos
                    Kyoto; and full web copy for Micro Lub, a UK-based food-tech startup.
                </p>
                <p>He is based in Osaka.</p>
            </div>
        </div>
    </div>
</BaseLayout>
