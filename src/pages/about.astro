---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="About"
    description="Edward Hewes is a freelance writer working across editorial and commercial projects."
>
    <div class="page-content page-content--narrow">
        <h1 class="page-title">About</h1>
        <div class="about-body">
            <p>
                Edward Hewes is a freelance writer working across editorial and
                commercial projects.
            </p>
            <p>
                His editorial work appears regularly in Time Out Osaka and The
                Japan Times, where he covers culture, food, events, and
                neighbourhoods across Japan.
            </p>
            <p>
                On the commercial side, he writes SEO and marketing content for
                international brands — including a caffeine and tea history piece
                for Ito-en, a blog post for Hotel Tavinos Kyoto, and full web
                copy for Micro Lub.
            </p>
            <p>He is based in Osaka.</p>
        </div>
    </div>
</BaseLayout>
